generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth & Users ───────────────────────────────────────────

enum Role {
  COACH
  CLIENT
}

enum ClientStatus {
  INTAKE
  ACTIVE
  PAUSED
  GRADUATED
}

enum DashboardMode {
  MINIMAL
  STANDARD
  DATA_HEAVY
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  role          Role
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Coach-specific
  credentials   String?
  bio           String?

  // Client-specific
  coachId       String?
  coach         User?     @relation("CoachClients", fields: [coachId], references: [id])
  clients       User[]    @relation("CoachClients")

  age           Int?
  gender        String?
  height        String?
  ethnicity     String?
  status        ClientStatus?
  dashboardMode DashboardMode @default(STANDARD)

  // Relations
  intakeSubmissions IntakeSubmission[]
  plans             Plan[]
  trackerTemplates  TrackerTemplate[]
  dailyCheckIns     DailyCheckIn[]
  weeklyReviews     WeeklyReview[]

  // NextAuth
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── System 1: Intake ───────────────────────────────────────

enum IntakeStatus {
  IN_PROGRESS
  COMPLETE
}

model IntakeSubmission {
  id          String       @id @default(cuid())
  clientId    String
  client      User         @relation(fields: [clientId], references: [id])
  status      IntakeStatus @default(IN_PROGRESS)
  currentSection Int       @default(0)
  submittedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  responses   IntakeResponse[]
}

enum InputMethod {
  TYPED
  VOICE
}

model IntakeResponse {
  id              String           @id @default(cuid())
  submissionId    String
  submission      IntakeSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  sectionKey      String
  questionKey     String
  value           Json
  inputMethod     InputMethod      @default(TYPED)
  rawVoiceTranscript String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([submissionId, sectionKey, questionKey])
}

// ─── System 2: Plan ─────────────────────────────────────────

enum PlanStatus {
  DRAFT
  COACH_REVIEW
  APPROVED
  DELIVERED
}

model Plan {
  id               String     @id @default(cuid())
  clientId         String
  client           User       @relation(fields: [clientId], references: [id])
  version          Int        @default(1)
  status           PlanStatus @default(DRAFT)
  coachDecisions   Json?
  generatedContent Json?
  coachEdits       Json?
  approvedAt       DateTime?
  deliveredAt      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  sections         PlanSection[]
  trackerTemplates TrackerTemplate[]
}

model PlanSection {
  id          String @id @default(cuid())
  planId      String
  plan        Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  sectionType String
  content     String
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── System 3: Tracker + Weekly Review ──────────────────────

model TrackerTemplate {
  id        String   @id @default(cuid())
  clientId  String
  client    User     @relation(fields: [clientId], references: [id])
  planId    String?
  plan      Plan?    @relation(fields: [planId], references: [id])
  fields    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DailyCheckIn {
  id              String   @id @default(cuid())
  clientId        String
  client          User     @relation(fields: [clientId], references: [id])
  date            DateTime @db.Date
  responses       Json
  voiceNoteUrl    String?
  voiceTranscript String?
  submittedAt     DateTime @default(now())
  createdAt       DateTime @default(now())

  @@unique([clientId, date])
}

enum ReviewStatus {
  GENERATING
  COACH_REVIEW
  APPROVED
  DELIVERED
}

model WeeklyReview {
  id             String       @id @default(cuid())
  clientId       String
  client         User         @relation(fields: [clientId], references: [id])
  weekStartDate  DateTime     @db.Date
  status         ReviewStatus @default(GENERATING)
  synthesisData  Json?
  citations      Json?
  coachFeedback  String?
  approvedAt     DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([clientId, weekStartDate])
}
